# SAP ADT Connection Configuration
# Copy this file to .env and fill in your SAP system details

# SAP Host (including protocol and port)
# Example: https://sapdev.company.com:8000
SAP_HOST=

# SAP Client (default: 100)
SAP_CLIENT=100

# SAP Username
SAP_USERNAME=

# SAP Password
SAP_PASSWORD=

# ====================================================================
# NATS Integration (Optional)
# ====================================================================
# Operational mode: stdio (default), nats, or dual
# - stdio: Claude Desktop integration (default)
# - nats: Orchestrator integration via NATS
# - dual: Both stdio and NATS simultaneously
ABAPER_MODE=stdio

# NATS Server URL (required for nats/dual mode)
# Loaded from Vault (infra/nats/cai) or set here
NATS_URL=

# NATS Credentials file path (required for nats/dual mode)
# Example: /var/nats/creds/user.creds
NATS_CREDS=

# Enable NATS Key-Value store (default: false)
# When enabled, SAP config can be loaded from NATS KV
NATS_ENABLE_KV=false

# Enable NATS messaging (default: false)
# Required for orchestrator integration
NATS_ENABLE_MESSAGING=false

# NATS KV Bucket name (default: AbaperMCPConfigBucket)
NATS_KV_BUCKET=AbaperMCPConfigBucket
